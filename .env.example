# Copy to ".env" in this folder and set values. ".env" is gitignored.
OPENROUTER_API_KEY=
# Meal parse only (vague / unstructured text). Not used when USDA+DB resolves the log.
# Default: GPT-5.4 Mini (better than nano for multilingual + composite meals). Override with openai/gpt-5.4-nano to save cost.
OPENROUTER_MODEL=openai/gpt-5.4-mini
# Optional: lower if you get HTTP 402 on low balance (default 3000).
# OPENROUTER_MAX_TOKENS=1024

# Optional: per-food sanity guardrail after deterministic lookup (small JSON).
# When enabled, you must set LLM_SANITY_MODEL (no default in code).
# LLM_SANITY_CHECK_ENABLED=1
# LLM_SANITY_MODEL=openai/gpt-5.4-nano

# Tests: live OpenRouter meal-LLM integration (`tests/test_openrouter_integration.py`) — opt-in only.
# Without this, pytest does not call the mini meal model even if OPENROUTER_API_KEY is set.
# RUN_LIVE_OPENROUTER=1

# USDA FoodData Central — free API key (meal logging + autocomplete hints both use this).
# https://fdc.nal.usda.gov/api-key-signup
USDA_FDC_API_KEY=
# Optional: skip USDA lookups (e.g. offline dev).
# USDA_FDC_DISABLED=1

# Optional: frontend (`frontend/.env`) — override API origin for Vite dev server
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: skip Open Food Facts HTTP; USDA FDC (if configured) and static fallback still apply before LLM.
# OPENFOODFACTS_DISABLED=1
# Custom User-Agent for OFF (recommended for production traffic).
# OPENFOODFACTS_USER_AGENT=MyApp/1.0 (contact@example.com)
